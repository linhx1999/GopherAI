# ===================================
# GopherAI 配置文件
# 复制此文件为 .env 并填写实际值
# ===================================

# 应用配置
APP_NAME=GopherAI
APP_HOST=0.0.0.0
APP_PORT=9090

# PostgreSQL 配置
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DB=gopherai
POSTGRES_SSL_MODE=disable

# Redis 配置（仅用于验证码缓存）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=root
RABBITMQ_PASSWORD=xxx
RABBITMQ_VHOST=/

# JWT 配置
JWT_SECRET_KEY=your-secret-key-here
JWT_EXPIRE_DURATION=8760
JWT_ISSUER=huanheart
JWT_SUBJECT=GopherAI

# Email 配置 (QQ邮箱)
EMAIL_AUTHCODE=xxx
EMAIL_FROM=xxx@qq.com

# OpenAI 兼容 API 配置
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL_NAME=deepseek-v3.2
OPENAI_BASE_URL=https://aihubmix.com/v1

# RAG 模型配置 (阿里云)
RAG_EMBEDDING_MODEL=text-embedding-v4
RAG_CHAT_MODEL=qwen-turbo
RAG_DOC_DIR=./docs
RAG_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_DIMENSION=1024

# 语音服务配置 (百度)
VOICE_API_KEY=xxx
VOICE_SECRET_KEY=xxx

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gopherai
MINIO_USE_SSL=false